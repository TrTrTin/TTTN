---
const { name, price } = Astro.props;
---

<div class="bg-white rounded-lg shadow-md p-4 hover:scale-105 duration-300">
    <img
        src="https://placehold.co/300x200"
        alt={name}
        class="w-full rounded"
    >

    <h3 class="mt-3 text-lg font-bold">
        {name}
    </h3>

    <p class="text-red-500 font-semibold">
        {price}
    </p>

    <button
        class="mt-3 bg-orange-500 text-white px-4 py-2 rounded hover:bg-orange-600"
    >
        Mua ngay
    </button>
</div>